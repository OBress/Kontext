# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Used by CLI for remote operations (supabase link, db push, db dump, type gen)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password

# Service role key — REQUIRED for backend (ingestion, MCP, team management)
# Find it: Supabase Dashboard → Settings → API → service_role key (secret)
# ⚠️ NEVER expose to client / NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub OAuth ────────────────────────────────────
# Configured in Supabase Dashboard > Auth > Providers > GitHub
# No env vars needed here — the redirect URL is handled by Supabase

# ─── Google AI Studio (BYOK — user provides at runtime) ─
# Not stored in env — passed via x-google-api-key header from client
