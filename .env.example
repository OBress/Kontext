# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Used by CLI for remote operations (supabase link, db push, db dump, type gen)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password

# Service role key — REQUIRED for backend (ingestion, MCP, team management)
# Find it: Supabase Dashboard → Settings → API → service_role key (secret)
# ⚠️ NEVER expose to client / NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub OAuth ────────────────────────────────────
# Required for silent GitHub token refresh (same creds as Supabase Auth > Providers > GitHub)
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_SECRET=your-github-oauth-client-secret

# ─── GitHub Webhooks ─────────────────────────────────────
# Shared secret for verifying webhook signatures (generate a random string)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here


# Public URL where webhooks are received (Cloudflare tunnel or Railway URL)
NEXT_PUBLIC_SITE_URL=https://webhook.yourdomain.com
