{
  "name": "black-friday-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint",
    "start": "next start",
    "db:migration:new": "supabase migration new",
    "db:push": "supabase db push && npm run db:dump && npm run db:types",
    "db:dump": "supabase db dump --linked -f supabase/schema.sql",
    "db:types": "supabase gen types typescript --linked > types/database.types.ts",
    "db:diff": "supabase db diff --linked -f",
    "db:reset:remote": "supabase db reset --linked && npm run db:dump && npm run db:types"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "latest",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.25",
    "jiti": "latest",
    "lucide-react": "0.555.0",
    "next": "16.0.6",
    "prop-types": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "1.0.7",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "postcss": "8.5.6",
    "supabase": "^2.84.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
